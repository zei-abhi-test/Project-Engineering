generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shipment {
  id          Int      @id @default(autoincrement())
  trackingId  String   @unique
  status      String   @default("PENDING")
  origin      String
  destination String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
