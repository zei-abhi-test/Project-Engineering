# Database Connection (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/launchpad

# JWT Secret - Minimum 32 chars recommended for production
JWT_SECRET=your_jwt_secret_here_min_32_chars

# CORS Configuration (GAP 3 - Item 05)
# In production, set this to your frontend URL
CORS_ORIGIN=http://localhost:5173

# Environment
NODE_ENV=development
PORT=3001

# Frontend specific (if using a separate domain/port)
VITE_API_BASE_URL=http://localhost:3001/api
