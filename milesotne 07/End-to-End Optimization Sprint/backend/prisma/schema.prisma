generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Mission {
  id          Int      @id @default(autoincrement())
  name        String
  launchDate  DateTime
  rocket      String
  description String
  crew        Crew[]
  logs        Log[]
}

model Crew {
  id          Int     @id @default(autoincrement())
  name        String
  role        String
  nationality String
  missionId   Int
  mission     Mission @relation(fields: [missionId], references: [id])
}

model Log {
  id          Int      @id @default(autoincrement())
  timestamp   DateTime @default(now())
  event       String
  details     String
  missionId   Int
  mission     Mission  @relation(fields: [missionId], references: [id])
}
